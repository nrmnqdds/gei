# GEI - GoMaluum Entries Indexer Configuration
# Copy this file to .env and customize as needed

# Database Configuration
# SQLite database file path (will be created if it doesn't exist)
DATABASE_URL=sqlite://schedules.db

# Encryption Key
# IMPORTANT: Use a strong, random key in production!
# If not set, a random key will be generated (data will be lost on restart)
# To generate a secure key: openssl rand -base64 32
ENCRYPTION_KEY=my-super-secret-encryption-key-change-this-in-production

# Guard the write execution
ADMIN_KEY=secret
